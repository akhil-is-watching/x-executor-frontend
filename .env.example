# Frontend Bun server port (Hub uses 3000)
PORT=5173

# Server-only: proxy target; forwards /api/hub/* → Hub /api/hub/*
HUB_API_URL=http://localhost:3000

# Client: empty = same-origin /api/hub via dev proxy
PUBLIC_HUB_API_URL=

# Client: Hub public URL for OAuth start links (must hit Hub directly)
PUBLIC_HUB_PUBLIC_BASE_URL=http://localhost:3000

# Vercel: set PUBLIC_HUB_* in project env (build time). See README.md.
# Do not set PORT or HUB_API_URL on Vercel (static dist; Hub CORS for API).
